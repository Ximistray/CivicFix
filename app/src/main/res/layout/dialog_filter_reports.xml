<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/bg_profile_content">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/filter_reports"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/full_name" 
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#666666"
        android:layout_marginBottom="8dp"
        android:visibility="gone"/>

    <!-- Region Filter -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/my_region"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#666666"
        android:layout_marginBottom="8dp"/>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/dialogRegionTabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:tabIndicatorColor="?attr/colorPrimary"
        app:tabSelectedTextColor="?attr/colorPrimary"
        app:tabTextColor="#999999"
        app:tabMode="fixed">
        <com.google.android.material.tabs.TabItem android:text="@string/my_region"/>
        <com.google.android.material.tabs.TabItem android:text="@string/all_regions"/>
    </com.google.android.material.tabs.TabLayout>

    <!-- Status Filter -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/admin_pending"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#666666"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="8dp"/>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/dialogStatusTabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:tabIndicatorColor="?attr/colorPrimary"
        app:tabSelectedTextColor="?attr/colorPrimary"
        app:tabTextColor="#999999"
        app:tabMode="fixed">
        <com.google.android.material.tabs.TabItem android:text="@string/status_unsolved"/>
        <com.google.android.material.tabs.TabItem android:text="@string/status_solved"/>
    </com.google.android.material.tabs.TabLayout>

    <!-- Category Filter -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/problem_type"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#666666"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="8dp"/>

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/dialogCategoryChips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        app:selectionRequired="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipAll"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/type_all"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipPothole"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/type_pothole"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipTrash"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/type_trash"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipStreetlight"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/type_streetlight"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipRoad"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/type_road"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipOther"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/type_other"/>
    </com.google.android.material.chip.ChipGroup>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnApplyFilters"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:text="@string/apply_filters"
        app:cornerRadius="12dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnResetFilters"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/reset"
        android:textColor="#999999"/>

</LinearLayout>